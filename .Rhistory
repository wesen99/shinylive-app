# ============================================================
# Ifaa SEI Infrastructure Dashboard - Donor Summary View
# Clean, impactful, and message-focused
# ============================================================
library(shiny)
library(leaflet)
library(leaflet.extras)
library(bs4Dash)
library(dplyr)
library(plotly)
library(DT)
library(scales)
# -----------------------------
# Data Preparation (same as original)
# -----------------------------
to_num <- function(x) suppressWarnings(as.numeric(str_trim(as.character(x))))
`%||%` <- function(a, b) if (!is.null(a)) a else b
norm_name <- function(x) tolower(trimws(as.character(x)))
find_col <- function(nms, candidates) {
norm <- function(s) tolower(gsub("[^a-z0-9]", "", s))
nms_n <- norm(nms)
cand_n <- norm(candidates)
hit <- match(cand_n, nms_n)
if (all(is.na(hit))) return(NULL)
nms[hit[which(!is.na(hit))[1]]]
}
dis_bucket <- function(x) {
v <- tolower(str_trim(as.character(x %||% "")))
ifelse(v %in% c("yes","y","true","1"), "Yes",
ifelse(v %in% c("no","n","false","0"), "No", "N/A"))
}
handover_bucket <- function(x) {
v <- tolower(str_trim(as.character(x %||% "")))
ifelse(v %in% c("handed over", "handover", "yes"), "Handed Over",
ifelse(v %in% c("not handed over", "no"), "Not Handed Over", "Unknown"))
}
extract_first_number <- function(x) {
s <- as.character(x)
s <- str_replace_all(s, ",", "")
m <- str_extract(s, "\\d+(?:\\.\\d+)?")
suppressWarnings(as.numeric(m))
}
get_icon_name <- function(type) {
type_lower <- tolower(type)
if (grepl("health", type_lower)) return("hospital")
if (grepl("irrigation", type_lower)) return("tint")
if (grepl("water", type_lower)) return("water")
if (grepl("school", type_lower)) return("graduation-cap")
return("map-marker-alt")
}
color_to_awesome <- function(color) {
color_map <- c("#3B82F6" = "blue", "#10B981" = "green", "#F59E0B" = "orange",
"#EF4444" = "red", "#8B5CF6" = "purple", "#06B6D4" = "darkblue")
color_map[color] %||% "blue"
}
# Load data
file_path <- "data.csv"
raw <- read.csv(file_path, stringsAsFactors = FALSE, check.names = FALSE)
names(raw) <- str_replace_all(names(raw), "\\s+", "_")
status_col <- find_col(names(raw), c("Status", "Completion_Status"))
handover_col <- find_col(names(raw), c("Handover_Status", "Handed_Over"))
benef_col <- find_col(names(raw), c("Beneficiaries", "Beneficiaries_Reached"))
budget_col <- find_col(names(raw), c("Budget_Utilized_ETB", "Budget_ETB"))
dis_col <- find_col(names(raw), c("Disability_Access", "PWD_Access"))
df <- raw %>%
mutate(
id = row_number(),
Latitude = to_num(.data[["Latitude"]]),
Longitude = to_num(.data[["Longitude"]]),
Infrastructure_Type = str_squish(as.character(.data[["Infrastructure_Type"]])),
Name = str_squish(as.character(.data[["Name_of_Infrastructure"]])),
Woreda = str_squish(as.character(.data[["Woreda"]])),
Func_Class = ifelse(tolower(.data[["Functionality_Status"]]) %in% c("functional", "yes"), "Functional", "Not Functional"),
Status = if (!is.null(status_col)) str_squish(as.character(.data[[status_col]])) else NA,
Handover_Class = if (!is.null(handover_col)) handover_bucket(.data[[handover_col]]) else "Unknown",
Disability_Access = if (!is.null(dis_col)) dis_bucket(.data[[dis_col]]) else "N/A",
Beneficiary_Num = if (!is.null(benef_col)) extract_first_number(.data[[benef_col]]) else NA,
Budget_ETB = if (!is.null(budget_col)) to_num(.data[[budget_col]]) else NA
) %>%
filter(!is.na(Latitude), !is.na(Longitude))
# Color mapping
types <- sort(unique(df$Infrastructure_Type))
color_pool <- c("#3B82F6", "#10B981", "#F59E0B", "#EF4444", "#8B5CF6", "#06B6D4")
df <- df %>%
group_by(Infrastructure_Type) %>%
mutate(
Color = color_pool[cur_group_id() %% length(color_pool) + 1],
Icon = get_icon_name(Infrastructure_Type),
AwesomeColor = color_to_awesome(Color)
) %>%
ungroup()
