# ============================================================
# Ifaa SEI Infrastructure Dashboard - Donor Summary View
# Clean, impactful, and message-focused
# ============================================================
library(shiny)
library(leaflet)
library(leaflet.extras)
library(bs4Dash)
library(dplyr)
library(plotly)
library(DT)
library(scales)
library(stringr)
# -----------------------------
# Data Preparation
# -----------------------------
to_num <- function(x) suppressWarnings(as.numeric(str_trim(as.character(x))))
`%||%` <- function(a, b) if (!is.null(a)) a else b
find_col <- function(nms, candidates) {
norm <- function(s) tolower(gsub("[^a-z0-9]", "", s))
nms_n <- norm(nms)
cand_n <- norm(candidates)
hit <- match(cand_n, nms_n)
if (all(is.na(hit))) return(NULL)
nms[hit[which(!is.na(hit))[1]]]
}
dis_bucket <- function(x) {
v <- tolower(str_trim(as.character(x %||% "")))
ifelse(v %in% c("yes","y","true","1"), "Yes",
ifelse(v %in% c("no","n","false","0"), "No", "N/A"))
}
handover_bucket <- function(x) {
v <- tolower(str_trim(as.character(x %||% "")))
ifelse(v %in% c("handed over", "handover", "yes"), "Handed Over",
ifelse(v %in% c("not handed over", "no"), "Not Handed Over", "Unknown"))
}
extract_first_number <- function(x) {
s <- as.character(x)
s <- str_replace_all(s, ",", "")
m <- str_extract(s, "\\d+(?:\\.\\d+)?")
suppressWarnings(as.numeric(m))
}
# Vectorized icon function
get_icon_name <- function(type) {
type_lower <- tolower(as.character(type))
icons <- rep("map-marker-alt", length(type_lower))
icons[grepl("health", type_lower)] <- "hospital"
icons[grepl("irrigation", type_lower)] <- "tint"
icons[grepl("water", type_lower)] <- "water"
icons[grepl("school", type_lower)] <- "graduation-cap"
icons[grepl("rub", type_lower)] <- "warehouse"
icons[grepl("road", type_lower)] <- "road"
return(icons)
}
color_to_awesome <- function(color) {
color_map <- c("#3B82F6" = "blue", "#10B981" = "green", "#F59E0B" = "orange",
"#EF4444" = "red", "#8B5CF6" = "purple", "#06B6D4" = "darkblue")
sapply(color, function(c) color_map[c] %||% "blue")
}
# Load data
file_path <- "data.csv"
raw <- read.csv(file_path, stringsAsFactors = FALSE, check.names = FALSE)
names(raw) <- str_replace_all(names(raw), "\\s+", "_")
status_col <- find_col(names(raw), c("Status", "Completion_Status"))
handover_col <- find_col(names(raw), c("Handover_Status", "Handed_Over"))
benef_col <- find_col(names(raw), c("Beneficiaries", "Beneficiaries_Reached"))
budget_col <- find_col(names(raw), c("Budget_Utilized_ETB", "Budget_ETB"))
dis_col <- find_col(names(raw), c("Disability_Access", "PWD_Access"))
df <- raw %>%
mutate(
id = row_number(),
Latitude = to_num(.data[["Latitude"]]),
Longitude = to_num(.data[["Longitude"]]),
Infrastructure_Type = str_squish(as.character(.data[["Infrastructure_Type"]])),
Name = str_squish(as.character(.data[["Name_of_Infrastructure"]])),
Woreda = str_squish(as.character(.data[["Woreda"]])),
Func_Class = ifelse(tolower(.data[["Functionality_Status"]]) %in% c("functional", "yes"), "Functional", "Not Functional"),
Status = if (!is.null(status_col)) str_squish(as.character(.data[[status_col]])) else NA,
Handover_Class = if (!is.null(handover_col)) handover_bucket(.data[[handover_col]]) else "Unknown",
Disability_Access = if (!is.null(dis_col)) dis_bucket(.data[[dis_col]]) else "N/A",
Beneficiary_Num = if (!is.null(benef_col)) extract_first_number(.data[[benef_col]]) else NA,
Budget_ETB = if (!is.null(budget_col)) to_num(.data[[budget_col]]) else NA
) %>%
filter(!is.na(Latitude), !is.na(Longitude))
# Color mapping (vectorized)
color_pool <- c("#3B82F6", "#10B981", "#F59E0B", "#EF4444", "#8B5CF6", "#06B6D4")
type_list <- unique(df$Infrastructure_Type)
type_colors <- setNames(
color_pool[((seq_along(type_list) - 1) %% length(color_pool)) + 1],
type_list
)
df <- df %>%
mutate(
Color = type_colors[Infrastructure_Type],
Icon = get_icon_name(Infrastructure_Type),
AwesomeColor = color_to_awesome(Color)
)
# -----------------------------
# MINIMALIST DONOR UI
# -----------------------------
ui <- bs4DashPage(
title = "Ifaa SEI - Impact Dashboard",
dark = FALSE,
header = bs4DashNavbar(
title = tags$strong("Ifaa SEI | Infrastructure Impact"),
status = "white",
border = FALSE,
sidebarIcon = icon("map"),
controlbarIcon = NULL
),
sidebar = bs4DashSidebar(
skin = "light",
status = "primary",
collapsed = TRUE,
expandOnHover = TRUE,
tags$div(style = "padding: 15px;",
h5("Filters", class = "text-primary"),
selectInput("type", "Infrastructure Type", c("All", unique(df$Infrastructure_Type)), width = "100%"),
selectInput("woreda", "Woreda", c("All", unique(df$Woreda)), width = "100%"),
actionButton("reset", "Clear Filters", icon = icon("eraser"), class = "btn-sm btn-outline-primary", width = "100%"),
hr(),
p("Data: CRS Ifaa SEI", class = "text-muted small text-center")
)
),
body = bs4DashBody(
tags$style(HTML("
.small-box { border-radius: 8px; }
.content-wrapper { background: #f4f6f9; }
")),
fluidRow(
column(12, h3("Key Achievements", class = "text-primary", style = "margin-top: 10px;"))
),
fluidRow(
valueBoxOutput("total_infra", width = 3),
valueBoxOutput("beneficiaries", width = 3),
valueBoxOutput("functional_rate", width = 3),
valueBoxOutput("accessibility_rate", width = 3)
),
fluidRow(
column(12, h4("Geographic Coverage", class = "text-info", style = "margin-top: 10px;"))
),
fluidRow(
bs4Card(width = 12, status = "info", solidHeader = FALSE,
collapsible = FALSE, closable = FALSE,
leafletOutput("map", height = "500px"))
),
fluidRow(
column(6,
bs4Card(title = "Portfolio Mix", status = "success", solidHeader = FALSE,
plotlyOutput("type_chart", height = "300px"))
),
column(6,
bs4Card(title = "Status Overview", status = "warning", solidHeader = FALSE,
plotlyOutput("status_chart", height = "300px"))
)
),
fluidRow(
column(12,
bs4Card(title = "Infrastructure Summary by Type", status = "primary", solidHeader = FALSE,
DTOutput("summary_table"))
)
)
),
footer = bs4DashFooter(
left = tags$small("© 2024 CRS Ifaa SEI | Data for decision making"),
right = tags$small("Dashboard v3.0 - Donor Summary")
)
)
# -----------------------------
# SERVER
# -----------------------------
server <- function(input, output, session) {
filtered_data <- reactive({
x <- df
if(input$type != "All") x <- x[x$Infrastructure_Type == input$type, ]
if(input$woreda != "All") x <- x[x$Woreda == input$woreda, ]
x
})
observeEvent(input$reset, {
updateSelectInput(session, "type", selected = "All")
updateSelectInput(session, "woreda", selected = "All")
})
output$total_infra <- renderValueBox({
valueBox(value = nrow(filtered_data()), subtitle = "Total Infrastructure Sites",
icon = icon("building"), color = "primary")
})
output$beneficiaries <- renderValueBox({
total_benef <- sum(filtered_data()$Beneficiary_Num, na.rm = TRUE)
valueBox(value = comma(total_benef), subtitle = "People Reached",
icon = icon("users"), color = "green")
})
output$functional_rate <- renderValueBox({
d <- filtered_data()
pct <- round(100 * sum(d$Func_Class == "Functional", na.rm = TRUE) / nrow(d), 1)
valueBox(value = paste0(pct, "%"), subtitle = "Functional Rate",
icon = icon("check-circle"), color = "success")
})
output$accessibility_rate <- renderValueBox({
d <- filtered_data()
pct <- round(100 * sum(d$Disability_Access == "Yes", na.rm = TRUE) / nrow(d), 1)
valueBox(value = paste0(pct, "%"), subtitle = "Disability Accessible",
icon = icon("wheelchair"), color = "info")
})
output$map <- renderLeaflet({
leaflet() %>%
addProviderTiles(providers$CartoDB.Positron) %>%
setView(lng = 38.76, lat = 9.15, zoom = 6)
})
observe({
d <- filtered_data()
leafletProxy("map", data = d) %>%
clearMarkers() %>%
addAwesomeMarkers(
lng = ~Longitude, lat = ~Latitude,
icon = ~awesomeIcons(icon = Icon, iconColor = "white", markerColor = AwesomeColor),
label = ~paste(Name, "-", Infrastructure_Type),
popup = ~paste0("<strong>", Name, "</strong><br>",
"<b>Type:</b> ", Infrastructure_Type, "<br>",
"<b>Woreda:</b> ", Woreda, "<br>",
"<b>Status:</b> ", Func_Class, "<br>",
"<b>Disability Access:</b> ", Disability_Access, "<br>",
ifelse(!is.na(Beneficiary_Num), paste0("<b>Beneficiaries:</b> ", comma(Beneficiary_Num)), ""))
)
})
output$type_chart <- renderPlotly({
d <- filtered_data()
counts <- table(d$Infrastructure_Type)
df_plot <- data.frame(Type = names(counts), Count = as.numeric(counts))
plot_ly(df_plot, x = ~Count, y = ~reorder(Type, Count), type = "bar",
orientation = "h", marker = list(color = "#3B82F6")) %>%
layout(xaxis = list(title = "Number of Sites"), yaxis = list(title = ""), margin = list(l = 100))
})
output$status_chart <- renderPlotly({
d <- filtered_data()
status_data <- data.frame(
Status = c("Functional", "Needs Attention"),
Count = c(sum(d$Func_Class == "Functional"), sum(d$Func_Class == "Not Functional"))
)
plot_ly(status_data, labels = ~Status, values = ~Count, type = "pie",
marker = list(colors = c("#10B981", "#EF4444")),
textinfo = "label+percent") %>%
layout(showlegend = FALSE)
})
output$summary_table <- renderDT({
d <- filtered_data()
summary <- d %>%
group_by(Infrastructure_Type) %>%
summarise(
Sites = n(),
Functional = sum(Func_Class == "Functional"),
`Disability Access` = sum(Disability_Access == "Yes"),
Beneficiaries = comma(sum(Beneficiary_Num, na.rm = TRUE)),
.groups = "drop"
)
datatable(summary,
options = list(pageLength = 10, dom = "t", scrollX = TRUE),
class = "compact stripe hover",
rownames = FALSE)
})
}
shinyApp(ui, server)
runApp('~/ifaa-dashboard_')
library(shinylive)
shinylive::export(".", "site")
library(shinylive)
shinylive::export(".", "site")
httpuv::runStaticServer("site/")
runApp('~/ifaa-dashboard_')
shinylive::export(".", "site")
